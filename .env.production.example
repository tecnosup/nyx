# =============================================================================
# NYX — variáveis de ambiente de produção
# =============================================================================
# Copie cada valor para o painel da Vercel (Project → Settings → Environment
# Variables). NÃO cole este arquivo preenchido no repo.
# =============================================================================

# -----------------------------------------------------------------------------
# Site (public)
# -----------------------------------------------------------------------------
# URL pública. Começa como o domínio da Vercel; troca para o domínio real
# quando o cliente comprar. É usada em sitemap, robots, canonical e OG.
NEXT_PUBLIC_SITE_URL=https://nyx.vercel.app

# WhatsApp de checkout (formato internacional, só dígitos)
NEXT_PUBLIC_WHATSAPP_NUMBER=5512981646555

# Google Analytics 4 — opcional. Deixe vazio para desativar o GA.
NEXT_PUBLIC_GA_ID=

# -----------------------------------------------------------------------------
# Firebase client (public — pode aparecer no bundle, é seguro)
# Pegar em: console.firebase.google.com → Project Settings → Your apps → Web
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# -----------------------------------------------------------------------------
# Firebase Admin SDK (SECRETO — nunca expor no client)
# Pegar em: console.firebase.google.com → Project Settings → Service Accounts
# → Generate new private key → abrir o JSON baixado
# -----------------------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# IMPORTANTE: cole a private key entre aspas duplas, mantendo \n literal
# (dois caracteres) no lugar das quebras de linha. O código reconverte.
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------------------------------
# Cloudinary (uploads de imagem do admin)
# Pegar em: cloudinary.com/console → Dashboard
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -----------------------------------------------------------------------------
# Proteção de rotas internas (SECRETO)
# Usado em /api/seed e /api/admin/set-claim — só para setup/migração inicial.
# Gere com: openssl rand -hex 32
# -----------------------------------------------------------------------------
SEED_SECRET=
